<div style="max-width:1100px;margin:0 auto;padding:4rem 2rem 6rem;">

  <!-- Page heading -->
  <div style="margin-bottom:3rem;">
    <p class="eyebrow" style="color:var(--pink);margin-bottom:0.5rem;">Your Bag</p>
    <h1 class="display" style="font-size:clamp(2.2rem,5vw,3.5rem);color:var(--dark);">
      {%- if cart.item_count == 0 -%}Your bag is empty{%- else -%}Review your order{%- endif -%}
    </h1>
  </div>

  {%- if cart.item_count == 0 -%}

    <!-- Empty state -->
    <div style="text-align:center;padding:4rem 2rem;border:2px dashed rgba(0,0,0,0.08);border-radius:20px;max-width:480px;margin:0 auto;">
      <div style="width:64px;height:64px;background:rgba(225,0,114,0.07);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="1.75"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      </div>
      <h2 style="font-weight:700;font-size:1.15rem;color:var(--dark);margin-bottom:0.5rem;">Nothing here yet</h2>
      <p style="color:#888;font-size:0.9rem;line-height:1.6;margin-bottom:2rem;">Head to the shop and find something you'll love.</p>
      <a href="{{ routes.root_url }}collections/all" class="btn-dark">Browse products</a>
    </div>

  {%- else -%}

    <div style="display:grid;grid-template-columns:1fr 340px;gap:3rem;align-items:start;" class="cart-layout">

      <!-- Left: line items -->
      <div>
        <form action="{{ routes.cart_url }}" method="post" id="cart-form">

          <!-- Items list -->
          <div style="display:flex;flex-direction:column;gap:0;">
            {%- for item in cart.items -%}
            <div class="cart-item" style="display:grid;grid-template-columns:88px 1fr;gap:1.25rem;padding:1.5rem 0;border-bottom:1px solid rgba(0,0,0,0.07);align-items:start;" data-index="{{ forloop.index }}">

              <!-- Image -->
              <a href="{{ item.url }}" style="display:block;border-radius:14px;overflow:hidden;aspect-ratio:1;background:#f5f5f3;flex-shrink:0;">
                {%- if item.image -%}
                  <img src="{{ item.image | image_url: width: 180 }}" alt="{{ item.title | escape }}"
                    style="width:100%;height:100%;object-fit:cover;" loading="lazy">
                {%- else -%}
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,var(--deep),var(--pink));opacity:0.15;"></div>
                {%- endif -%}
              </a>

              <!-- Details -->
              <div style="display:flex;flex-direction:column;gap:0.5rem;">
                <div style="display:flex;justify-content:space-between;align-items:flex-start;gap:1rem;">
                  <div>
                    <a href="{{ item.url }}" style="font-weight:700;font-size:0.95rem;color:var(--dark);text-decoration:none;display:block;margin-bottom:0.2rem;">{{ item.product.title }}</a>
                    {%- unless item.variant.title == 'Default Title' -%}
                      <p style="font-size:0.78rem;color:#999;text-transform:uppercase;letter-spacing:0.08em;font-weight:600;">{{ item.variant.title }}</p>
                    {%- endunless -%}
                  </div>
                  <!-- Line price -->
                  <div style="text-align:right;flex-shrink:0;">
                    <p style="font-weight:800;font-size:1rem;color:var(--dark);">{{ item.line_price | money }}</p>
                    {%- if item.original_line_price != item.line_price -%}
                      <p style="font-size:0.78rem;color:#aaa;text-decoration:line-through;">{{ item.original_line_price | money }}</p>
                    {%- endif -%}
                  </div>
                </div>

                <!-- Unit price -->
                <p style="font-size:0.75rem;color:#bbb;">{{ item.price | money }} each</p>

                <!-- Qty + remove -->
                <div style="display:flex;align-items:center;gap:1rem;margin-top:0.25rem;">
                  <div style="display:flex;align-items:center;border:1px solid rgba(0,0,0,0.12);border-radius:9999px;overflow:hidden;">
                    <button type="button" class="qty-btn cart-qty-dec" data-index="{{ forloop.index }}" data-qty="{{ item.quantity }}"
                      style="width:34px;height:34px;background:#fff;border:none;cursor:pointer;font-size:1rem;font-weight:700;color:var(--dark);transition:background 0.15s;display:flex;align-items:center;justify-content:center;">−</button>
                    <input type="number" name="updates[]" value="{{ item.quantity }}" min="0"
                      id="qty-{{ forloop.index }}"
                      style="width:38px;height:34px;border:none;border-left:1px solid rgba(0,0,0,0.08);border-right:1px solid rgba(0,0,0,0.08);text-align:center;font-family:'Jost',sans-serif;font-weight:700;font-size:0.88rem;color:var(--dark);outline:none;-moz-appearance:textfield;background:#fff;">
                    <button type="button" class="qty-btn cart-qty-inc" data-index="{{ forloop.index }}" data-qty="{{ item.quantity }}"
                      style="width:34px;height:34px;background:#fff;border:none;cursor:pointer;font-size:1rem;font-weight:700;color:var(--dark);transition:background 0.15s;display:flex;align-items:center;justify-content:center;">+</button>
                  </div>
                  <button type="button" class="cart-remove" data-index="{{ forloop.index }}"
                    style="background:none;border:none;font-size:0.72rem;font-weight:700;letter-spacing:0.1em;text-transform:uppercase;color:#bbb;cursor:pointer;transition:color 0.2s;font-family:'Jost',sans-serif;padding:0;">
                    Remove
                  </button>
                </div>

              </div>
            </div>
            {%- endfor -%}
          </div>

          <!-- Cart note -->
          <div style="margin-top:1.5rem;">
            <label for="cart-note" style="font-weight:700;font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:#aaa;display:block;margin-bottom:0.5rem;">Order note (optional)</label>
            <textarea name="note" id="cart-note" rows="2" placeholder="Any special instructions…"
              style="width:100%;border:1.5px solid rgba(0,0,0,0.1);border-radius:12px;padding:0.75rem 1rem;font-family:'Jost',sans-serif;font-size:0.88rem;color:var(--dark);resize:vertical;outline:none;transition:border-color 0.2s;">{{ cart.note }}</textarea>
          </div>

        </form>
      </div>

      <!-- Right: order summary -->
      <div style="position:sticky;top:110px;">
        <div style="border:1.5px solid rgba(0,0,0,0.08);border-radius:20px;padding:2rem;background:#fafaf8;">

          <h2 style="font-weight:900;font-size:1rem;letter-spacing:-0.01em;color:var(--dark);margin-bottom:1.5rem;text-transform:uppercase;">Order summary</h2>

          <!-- Subtotal rows -->
          <div style="display:flex;flex-direction:column;gap:0.75rem;padding-bottom:1.25rem;border-bottom:1px solid rgba(0,0,0,0.07);margin-bottom:1.25rem;">
            <div style="display:flex;justify-content:space-between;">
              <span style="font-size:0.88rem;color:#666;">Subtotal ({{ cart.item_count }} item{{ cart.item_count | plural: '', 's' }})</span>
              <span style="font-weight:700;font-size:0.88rem;color:var(--dark);">{{ cart.total_price | money }}</span>
            </div>
            <div style="display:flex;justify-content:space-between;">
              <span style="font-size:0.88rem;color:#666;">Shipping</span>
              <span style="font-size:0.88rem;color:#999;">Calculated at checkout</span>
            </div>
          </div>

          <!-- Discount savings row (hidden until code applied) -->
          <div id="discount-row" style="display:none;justify-content:space-between;align-items:center;padding:0.6rem 0.85rem;background:rgba(225,0,114,0.06);border-radius:10px;margin-bottom:0.75rem;">
            <span id="discount-label" style="font-size:0.82rem;color:var(--pink);font-weight:600;">Discount</span>
            <span id="discount-amount" style="font-size:0.82rem;color:var(--pink);font-weight:700;">−£0.00</span>
          </div>

          <!-- Total -->
          <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:1.75rem;">
            <span style="font-weight:800;font-size:1rem;color:var(--dark);">Total</span>
            <div style="text-align:right;">
              <span id="cart-total-original" style="font-size:0.78rem;color:#bbb;text-decoration:line-through;display:none;margin-bottom:2px;display:block;">{{ cart.total_price | money }}</span>
              <span id="cart-total-display" data-cents="{{ cart.total_price }}" style="font-weight:900;font-size:1.4rem;color:var(--dark);letter-spacing:-0.02em;">{{ cart.total_price | money }}</span>
            </div>
          </div>

          <!-- Discount code -->
          <div style="margin-bottom:1.5rem;">
            <label for="discount-input" style="font-weight:700;font-size:0.68rem;letter-spacing:0.14em;text-transform:uppercase;color:#aaa;display:block;margin-bottom:0.5rem;">Discount code</label>
            <div style="display:flex;gap:0.5rem;">
              <input type="text" id="discount-input" placeholder="e.g. FAMILIA10"
                style="flex:1;border:1.5px solid rgba(0,0,0,0.1);border-radius:9999px;padding:0.65rem 1rem;font-family:'Jost',sans-serif;font-size:0.82rem;outline:none;transition:border-color 0.2s;color:var(--dark);">
              <button type="button" id="apply-discount"
                style="background:var(--dark);color:#fff;border:none;border-radius:9999px;padding:0.65rem 1.1rem;font-family:'Jost',sans-serif;font-weight:700;font-size:0.68rem;letter-spacing:0.12em;text-transform:uppercase;cursor:pointer;white-space:nowrap;transition:background 0.2s;">Apply</button>
            </div>
            <p id="discount-msg" style="display:none;font-size:0.75rem;margin-top:0.5rem;padding-left:0.25rem;"></p>
          </div>

          <!-- Checkout -->
          <a href="/checkout" id="checkout-btn"
            style="display:block;width:100%;background:var(--pink);color:#fff;font-family:'Jost',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;padding:1.1rem 1.5rem;border-radius:9999px;text-decoration:none;text-align:center;border:2px solid var(--pink);transition:background 0.2s,transform 0.22s cubic-bezier(0.34,1.56,0.64,1),color 0.2s;margin-bottom:0.75rem;">
            Proceed to Checkout
          </a>
          <a href="{{ routes.root_url }}collections/all"
            style="display:block;text-align:center;font-size:0.78rem;font-weight:600;color:#aaa;text-decoration:none;transition:color 0.2s;letter-spacing:0.06em;">
            ← Continue shopping
          </a>

          <!-- Trust signals -->
          <div style="margin-top:1.75rem;padding-top:1.25rem;border-top:1px solid rgba(0,0,0,0.07);display:flex;flex-direction:column;gap:0.6rem;">
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>
              <span style="font-size:0.72rem;color:#888;">Secure checkout</span>
            </div>
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
              <span style="font-size:0.72rem;color:#888;">Free delivery over £30</span>
            </div>
            <div style="display:flex;align-items:center;gap:0.6rem;">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--pink)" stroke-width="2"><polyline points="23 4 23 10 17 10"/><path d="M20.49 15a9 9 0 11-2.12-9.36L23 10"/></svg>
              <span style="font-size:0.72rem;color:#888;">Easy returns</span>
            </div>
          </div>

        </div>
      </div>

    </div>

  {%- endif -%}

</div>

<script>
(function() {

  /* ────────────────────────────────────────────
     QTY CONTROLS — robust, blocks double-clicks
  ──────────────────────────────────────────── */
  var updating = false;

  function setCartItemLoading(itemEl, loading) {
    var btns = itemEl.querySelectorAll('.cart-qty-dec, .cart-qty-inc, .cart-remove');
    btns.forEach(function(b) {
      b.disabled = loading;
      b.style.opacity = loading ? '0.4' : '1';
      b.style.cursor  = loading ? 'wait' : 'pointer';
    });
  }

  function updateLineItem(index, qty, itemEl) {
    if (updating) return;
    updating = true;
    setCartItemLoading(itemEl, true);

    fetch('/cart/change.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'Accept': 'application/json' },
      body: JSON.stringify({ line: parseInt(index, 10), quantity: qty })
    })
    .then(function(res) {
      if (!res.ok) throw new Error('Cart update failed');
      return res.json();
    })
    .then(function() {
      location.reload();
    })
    .catch(function() {
      updating = false;
      setCartItemLoading(itemEl, false);
      alert('Could not update your bag. Please try again.');
    });
  }

  document.querySelectorAll('.cart-qty-dec, .cart-qty-inc').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (updating) return;
      var index  = btn.dataset.index;
      var itemEl = btn.closest('.cart-item');
      var input  = document.getElementById('qty-' + index);
      var val    = parseInt(input.value, 10) || 1;
      var next   = btn.classList.contains('cart-qty-inc') ? val + 1 : Math.max(0, val - 1);
      input.value = next;
      updateLineItem(index, next, itemEl);
    });
  });

  document.querySelectorAll('.cart-remove').forEach(function(btn) {
    btn.addEventListener('click', function() {
      if (updating) return;
      var itemEl = btn.closest('.cart-item');
      updateLineItem(btn.dataset.index, 0, itemEl);
    });
  });

  /* ────────────────────────────────────────────
     DISCOUNT CODE — savings breakdown
  ──────────────────────────────────────────── */
  /* Known codes: add/update as needed */
  var DISCOUNT_CODES = {
    'FAMILIA10': { type: 'percent', value: 10 },
    'HOLA10':    { type: 'percent', value: 10 },
  };

  function formatMoney(cents) {
    return '£' + (cents / 100).toFixed(2);
  }

  var discountInput = document.getElementById('discount-input');
  var applyBtn      = document.getElementById('apply-discount');
  var checkoutBtn   = document.getElementById('checkout-btn');
  var discountRow   = document.getElementById('discount-row');
  var discountLabel = document.getElementById('discount-label');
  var discountAmt   = document.getElementById('discount-amount');
  var totalDisplay  = document.getElementById('cart-total-display');
  var totalOriginal = document.getElementById('cart-total-original');
  var discountMsg   = document.getElementById('discount-msg');

  if (discountInput) {
    discountInput.addEventListener('focus', function() { discountInput.style.borderColor = 'var(--pink)'; });
    discountInput.addEventListener('blur',  function() { discountInput.style.borderColor = 'rgba(0,0,0,0.1)'; });
  }

  if (applyBtn && discountInput && checkoutBtn) {
    applyBtn.addEventListener('click', function() {
      var raw  = (discountInput.value || '').trim();
      var code = raw.toUpperCase();
      if (!code) return;

      var totalCents = parseInt(totalDisplay.dataset.cents, 10) || 0;
      var rule = DISCOUNT_CODES[code];

      /* Update checkout URL so discount auto-applies */
      checkoutBtn.href = '/checkout?discount=' + encodeURIComponent(code);

      if (rule) {
        var savingCents = rule.type === 'percent'
          ? Math.round(totalCents * rule.value / 100)
          : Math.min(rule.value * 100, totalCents);
        var newTotalCents = totalCents - savingCents;

        /* Show savings row */
        discountLabel.textContent = 'Discount (' + code + ' — ' + (rule.type === 'percent' ? rule.value + '%' : formatMoney(rule.value * 100) + ' off') + ')';
        discountAmt.textContent   = '−' + formatMoney(savingCents);
        discountRow.style.display = 'flex';

        /* Strike-through original, show new total */
        totalOriginal.textContent  = formatMoney(totalCents);
        totalOriginal.style.display = 'block';
        totalDisplay.textContent   = formatMoney(newTotalCents);
        totalDisplay.style.color   = 'var(--pink)';

        /* Confirmation message */
        discountMsg.textContent  = '✓ ' + code + ' applied — you\'re saving ' + formatMoney(savingCents) + '!';
        discountMsg.style.color  = 'var(--pink)';
        discountMsg.style.display = 'block';
      } else {
        /* Unknown code — pass it through, Shopify validates at checkout */
        discountMsg.textContent  = '✓ Code saved — your discount will appear at checkout.';
        discountMsg.style.color  = '#888';
        discountMsg.style.display = 'block';
      }

      /* Lock the field */
      applyBtn.textContent = '✓ Applied';
      applyBtn.style.background = 'var(--pink)';
      discountInput.disabled = true;
      discountInput.style.borderColor = 'rgba(225,0,114,0.3)';
      discountInput.style.color = 'var(--pink)';
    });
  }

  /* ── Focus styles for textarea ── */
  var noteInput = document.getElementById('cart-note');
  if (noteInput) {
    noteInput.addEventListener('focus', function() { noteInput.style.borderColor = 'var(--pink)'; });
    noteInput.addEventListener('blur',  function() { noteInput.style.borderColor = 'rgba(0,0,0,0.1)'; });
  }

  /* ── Checkout button hover ── */
  if (checkoutBtn) {
    checkoutBtn.addEventListener('mouseenter', function() {
      checkoutBtn.style.background   = '#c80068';
      checkoutBtn.style.borderColor  = '#c80068';
      checkoutBtn.style.transform    = 'translateY(-2px)';
    });
    checkoutBtn.addEventListener('mouseleave', function() {
      checkoutBtn.style.background   = 'var(--pink)';
      checkoutBtn.style.borderColor  = 'var(--pink)';
      checkoutBtn.style.transform    = 'translateY(0)';
    });
  }

})();
</script>

<style>
  @media (max-width: 760px) {
    .cart-layout { grid-template-columns: 1fr !important; }
  }
  input[type=number]::-webkit-inner-spin-button,
  input[type=number]::-webkit-outer-spin-button { -webkit-appearance: none; }
</style>
