{% comment %} Collection / Shop page {% endcomment %}

<section style="padding:5rem 2rem;background:#fff;min-height:60vh;">
  <div style="max-width:1100px;margin:0 auto;">

    <div class="reveal" style="margin-bottom:3.5rem;text-align:center;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:0.6rem;">{{ collection.title }}</p>
      <h1 class="display" style="font-size:clamp(2.8rem,5vw,4.2rem);color:var(--dark);">{{ collection.title }}</h1>
      {%- if collection.description != blank -%}
        <p style="font-size:0.95rem;color:#777;line-height:1.7;max-width:540px;margin:1.25rem auto 0;">{{ collection.description }}</p>
      {%- endif -%}
    </div>

    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(280px,420px));gap:2.25rem;justify-content:center;" class="products-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p style="color:#aaa;text-align:center;">No products found in this collection.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.pages > 1 -%}
      <div style="display:flex;justify-content:center;gap:0.75rem;margin-top:4rem;">
        {%- if paginate.previous -%}
          <a href="{{ paginate.previous.url }}" class="btn-dark">← Previous</a>
        {%- endif -%}
        {%- if paginate.next -%}
          <a href="{{ paginate.next.url }}" class="btn-dark">Next →</a>
        {%- endif -%}
      </div>
    {%- endif -%}

  </div>
</section>
