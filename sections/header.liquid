<nav style="position:sticky;top:0;z-index:200;background:rgba(255,255,255,0.97);backdrop-filter:blur(12px);border-bottom:1px solid rgba(0,0,0,0.07);">

  <!-- Desktop nav -->
  <div class="nav-desktop" style="max-width:1280px;margin:0 auto;padding:0.75rem 2rem;display:grid;grid-template-columns:1fr auto 1fr;align-items:center;gap:2rem;">
    <!-- Left links -->
    <div style="display:flex;align-items:center;gap:2.5rem;justify-content:flex-end;">
      <a href="{{ routes.root_url }}collections/all" class="nav-link">Shop</a>
      <a href="{{ pages['our-story'].url }}" class="nav-link">Our Story</a>
    </div>
    <!-- Centre logo -->
    <a href="{{ routes.root_url }}" style="flex-shrink:0;display:inline-block;text-align:center;">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 200 }}" alt="{{ shop.name }}"
          style="height:72px;width:auto;display:block;">
      {%- else -%}
        <span style="font-weight:900;font-size:1.5rem;letter-spacing:-0.03em;color:var(--pink);">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <!-- Right links + search -->
    <div style="display:flex;align-items:center;gap:2.5rem;justify-content:flex-start;">
      <a href="{{ routes.root_url }}#craft" class="nav-link">The Craft</a>
      <a href="{{ routes.root_url }}#newsletter" class="nav-link">Join</a>
      <button class="search-trigger icon-btn" aria-label="Search" style="background:none;border:none;cursor:pointer;padding:4px;display:flex;align-items:center;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile nav bar -->
  <div class="nav-mobile" style="display:none;padding:0.6rem 1.25rem;align-items:center;justify-content:space-between;">
    <a href="{{ routes.root_url }}" style="display:inline-block;flex-shrink:0;">
      {%- if section.settings.logo != blank -%}
        <img src="{{ section.settings.logo | image_url: width: 160 }}" alt="{{ shop.name }}"
          style="height:52px;width:auto;display:block;">
      {%- else -%}
        <span style="font-weight:900;font-size:1.25rem;letter-spacing:-0.03em;color:var(--pink);">{{ shop.name }}</span>
      {%- endif -%}
    </a>
    <div style="display:flex;align-items:center;gap:0.5rem;">
      <button class="search-trigger icon-btn" aria-label="Search" style="background:none;border:none;cursor:pointer;padding:6px;display:flex;align-items:center;justify-content:center;">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      </button>
      <button class="nav-hamburger" aria-label="Open menu" aria-expanded="false"
        style="background:none;border:none;cursor:pointer;padding:6px;color:var(--dark);display:flex;align-items:center;justify-content:center;">
        <svg class="icon-menu" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        <svg class="icon-close" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="display:none;"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="nav-drawer" style="display:none;flex-direction:column;border-top:1px solid rgba(0,0,0,0.07);padding:0.5rem 0 1rem;">
    <a href="{{ routes.root_url }}collections/all" class="nav-drawer-link">Shop</a>
    <a href="{{ pages['our-story'].url }}" class="nav-drawer-link">Our Story</a>
    <a href="{{ routes.root_url }}#craft" class="nav-drawer-link">The Craft</a>
    <a href="{{ routes.root_url }}#newsletter" class="nav-drawer-link">Join La Familia</a>
  </div>

</nav>

<!-- ─── Full-screen Search Overlay ─── -->
<div id="search-overlay" role="dialog" aria-modal="true" aria-label="Search"
  style="display:none;position:fixed;inset:0;z-index:500;background:rgba(15,10,18,0.96);backdrop-filter:blur(20px);-webkit-backdrop-filter:blur(20px);opacity:0;transition:opacity 0.3s ease;">
  <div style="max-width:680px;margin:0 auto;padding:5rem 2rem 2rem;position:relative;">

    <!-- Close -->
    <button id="search-close" aria-label="Close search"
      style="position:absolute;top:-3.5rem;right:0;background:none;border:none;color:rgba(255,255,255,0.5);cursor:pointer;padding:8px;display:flex;align-items:center;transition:color 0.2s;">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>

    <!-- Eyebrow -->
    <p class="eyebrow" style="color:rgba(255,255,255,0.35);margin-bottom:1.5rem;">Search</p>

    <!-- Input row -->
    <div style="display:flex;align-items:center;gap:1rem;border-bottom:2px solid var(--pink);padding-bottom:0.75rem;margin-bottom:2rem;">
      <svg style="flex-shrink:0;color:rgba(255,255,255,0.35);" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
      <input id="search-input" type="search" autocomplete="off" spellcheck="false"
        placeholder="Search products…"
        style="flex:1;background:none;border:none;outline:none;font-family:'Jost',sans-serif;font-size:clamp(1.4rem,3vw,2rem);font-weight:700;color:#fff;letter-spacing:-0.02em;caret-color:var(--pink);"
        aria-label="Search products">
      <button id="search-clear" aria-label="Clear"
        style="display:none;background:none;border:none;color:rgba(255,255,255,0.35);cursor:pointer;padding:4px;transition:color 0.2s;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
      </button>
    </div>

    <!-- Results -->
    <div id="search-results"></div>

    <!-- Quick links (shown when empty) -->
    <div id="search-quick" style="margin-top:0.5rem;">
      <p class="eyebrow" style="color:rgba(255,255,255,0.3);margin-bottom:1rem;">Quick links</p>
      <div style="display:flex;flex-wrap:wrap;gap:0.6rem;">
        <a href="{{ routes.root_url }}collections/all" class="search-pill">All Products</a>
        <a href="{{ pages['our-story'].url }}" class="search-pill">Our Story</a>
        <a href="{{ routes.root_url }}#newsletter" class="search-pill">Join La Familia</a>
      </div>
    </div>
  </div>
</div>

<script>
(function() {
  /* ── Hamburger ── */
  var btn = document.querySelector('.nav-hamburger');
  var drawer = document.querySelector('.nav-drawer');
  var iconMenu = btn.querySelector('.icon-menu');
  var iconClose = btn.querySelector('.icon-close');
  btn.addEventListener('click', function() {
    var open = drawer.style.display === 'flex';
    drawer.style.display = open ? 'none' : 'flex';
    iconMenu.style.display = open ? 'block' : 'none';
    iconClose.style.display = open ? 'none' : 'block';
    btn.setAttribute('aria-expanded', String(!open));
  });

  /* ── Full-screen Search ── */
  var overlay   = document.getElementById('search-overlay');
  var input     = document.getElementById('search-input');
  var results   = document.getElementById('search-results');
  var quick     = document.getElementById('search-quick');
  var clearBtn  = document.getElementById('search-clear');
  var triggers  = document.querySelectorAll('.search-trigger');
  var closeBtn  = document.getElementById('search-close');
  var debounce;

  function openSearch() {
    overlay.style.display = 'block';
    document.body.style.overflow = 'hidden';
    requestAnimationFrame(function() {
      overlay.style.opacity = '1';
      setTimeout(function() { input.focus(); }, 50);
    });
  }

  function closeSearch() {
    overlay.style.opacity = '0';
    document.body.style.overflow = '';
    setTimeout(function() {
      overlay.style.display = 'none';
      input.value = '';
      results.innerHTML = '';
      quick.style.display = 'block';
      clearBtn.style.display = 'none';
    }, 300);
  }

  triggers.forEach(function(t) { t.addEventListener('click', openSearch); });
  closeBtn.addEventListener('click', closeSearch);
  overlay.addEventListener('click', function(e) {
    if (e.target === overlay) closeSearch();
  });
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && overlay.style.display !== 'none') closeSearch();
  });

  clearBtn.addEventListener('click', function() {
    input.value = '';
    input.focus();
    results.innerHTML = '';
    quick.style.display = 'block';
    clearBtn.style.display = 'none';
  });

  function renderResults(items) {
    if (!items.length) {
      results.innerHTML = '<p style="color:rgba(255,255,255,0.4);font-size:0.9rem;">No products found. Try a different term.</p>';
      return;
    }
    results.innerHTML = items.map(function(p) {
      var img = p.featured_image
        ? '<img src="' + p.featured_image + '&width=80" alt="" style="width:56px;height:56px;object-fit:cover;border-radius:10px;flex-shrink:0;">'
        : '<div style="width:56px;height:56px;border-radius:10px;background:rgba(255,255,255,0.06);flex-shrink:0;"></div>';
      return '<a href="' + p.url + '" style="display:flex;align-items:center;gap:1rem;padding:0.85rem 0;border-bottom:1px solid rgba(255,255,255,0.06);text-decoration:none;transition:background 0.2s;" class="search-result-row">'
        + img
        + '<div><p style="color:#fff;font-weight:700;font-size:0.95rem;margin:0 0 0.2rem;">' + p.title + '</p>'
        + (p.price ? '<p style="color:var(--pink);font-size:0.8rem;font-weight:600;margin:0;">£' + (p.price / 100).toFixed(2) + '</p>' : '')
        + '</div></a>';
    }).join('');
  }

  input.addEventListener('input', function() {
    var q = input.value.trim();
    clearBtn.style.display = q ? 'flex' : 'none';
    if (!q) {
      results.innerHTML = '';
      quick.style.display = 'block';
      return;
    }
    quick.style.display = 'none';
    clearTimeout(debounce);
    debounce = setTimeout(function() {
      results.innerHTML = '<p style="color:rgba(255,255,255,0.3);font-size:0.85rem;padding:1rem 0;">Searching…</p>';
      fetch('/search/suggest.json?q=' + encodeURIComponent(q) + '&resources[type]=product&resources[limit]=6')
        .then(function(r) { return r.json(); })
        .then(function(data) {
          var items = (data.resources && data.resources.results && data.resources.results.products) || [];
          renderResults(items);
        })
        .catch(function() {
          results.innerHTML = '<p style="color:rgba(255,255,255,0.4);font-size:0.9rem;">Something went wrong. Try again.</p>';
        });
    }, 280);
  });
})();
</script>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    }
  ]
}
{% endschema %}
