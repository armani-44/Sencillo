<div style="background:var(--pink);padding:0 1.5rem;height:40px;display:flex;align-items:center;justify-content:space-between;position:relative;z-index:201;">

  <!-- Left: social icons -->
  <div style="display:flex;align-items:center;gap:1rem;flex-shrink:0;">
    <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.24 8.24 0 004.83 1.55V6.79a4.85 4.85 0 01-1.06-.1z"/></svg>
    </a>
    <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
    </a>
    <a href="{{ section.settings.snapchat_url }}" aria-label="Snapchat" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-12C24.007 5.367 18.641 0 12.017 0z"/></svg>
    </a>
    <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="14" height="14" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
    </a>
  </div>

  <!-- Centre: promo carousel -->
  <div style="position:absolute;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:1rem;">
    <button id="promoPrev" aria-label="Previous" style="background:none;border:none;cursor:pointer;color:var(--yellow);font-size:1rem;line-height:1;padding:0;opacity:0.85;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.85'">←</button>
    <div style="overflow:hidden;height:40px;display:flex;align-items:center;min-width:380px;justify-content:center;">
      <div id="promoTrack" style="display:flex;transition:transform 0.45s cubic-bezier(0.4,0,0.2,1);width:100%;">
        <span class="promo-msg" style="min-width:100%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:0.67rem;letter-spacing:0.15em;text-transform:uppercase;color:#fff;white-space:nowrap;">{{ section.settings.promo_1 }}</span>
        <span class="promo-msg" style="min-width:100%;display:flex;align-items:center;justify-content:center;font-weight:600;font-size:0.67rem;letter-spacing:0.15em;text-transform:uppercase;color:#fff;white-space:nowrap;">{{ section.settings.promo_2 }}</span>
      </div>
    </div>
    <button id="promoNext" aria-label="Next" style="background:none;border:none;cursor:pointer;color:var(--yellow);font-size:1rem;line-height:1;padding:0;opacity:0.85;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.85'">→</button>
  </div>

  <!-- Right: utility icons -->
  <div style="display:flex;align-items:center;gap:1.2rem;flex-shrink:0;">
    <a href="{{ routes.account_url }}" aria-label="Account" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
    </a>
    <a href="{{ routes.search_url }}" aria-label="Search" style="color:#fff;opacity:0.9;transition:opacity 0.2s;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
    </a>
    <a href="{{ routes.cart_url }}" aria-label="Cart" style="color:#fff;opacity:0.9;transition:opacity 0.2s;position:relative;" onmouseover="this.style.opacity='1'" onmouseout="this.style.opacity='0.9'">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
      <span class="cart-count" style="position:absolute;top:-5px;right:-7px;background:#fff;color:var(--pink);font-size:0.5rem;font-weight:700;width:14px;height:14px;border-radius:50%;display:flex;align-items:center;justify-content:center;">{{ cart.item_count }}</span>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Announcement Bar",
  "settings": [
    { "type": "text", "id": "promo_1", "label": "Promo message 1", "default": "Free delivery on all orders over £30" },
    { "type": "text", "id": "promo_2", "label": "Promo message 2", "default": "Use code HOLA10 for 10% off your first order" },
    { "type": "url",  "id": "tiktok_url",   "label": "TikTok URL" },
    { "type": "url",  "id": "instagram_url","label": "Instagram URL" },
    { "type": "url",  "id": "snapchat_url", "label": "Snapchat URL" },
    { "type": "url",  "id": "facebook_url", "label": "Facebook URL" }
  ]
}
{% endschema %}
