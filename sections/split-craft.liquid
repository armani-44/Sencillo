<section id="craft" style="display:grid;grid-template-columns:1fr 1fr;" class="split-grid">

  <!-- Left: deep copy -->
  <div style="position:relative;background:var(--deep);display:flex;align-items:center;justify-content:center;padding:5.5rem 4.5rem;overflow:hidden;" class="grainy">
    <div style="position:absolute;left:-10%;top:50%;transform:translateY(-50%);width:60%;opacity:0.05;filter:brightness(0) invert(1);pointer-events:none;">
      {%- if section.settings.watermark != blank -%}
        <img src="{{ section.settings.watermark | image_url: width: 600 }}" alt="" style="width:100%;height:auto;">
      {%- endif -%}
    </div>
    <div class="reveal" style="position:relative;z-index:1;">
      <p class="eyebrow" style="color:var(--yellow);margin-bottom:1.3rem;">{{ section.settings.eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.6rem,5vw,4rem);color:#fff;margin-bottom:0.5rem;text-shadow:0 4px 24px rgba(0,0,0,0.2);">
        {{ section.settings.heading | newline_to_br }}
      </h2>
      <div style="width:44px;height:3px;background:var(--pink);margin:1.75rem 0;border-radius:2px;"></div>
      <p style="font-weight:400;font-size:0.95rem;line-height:1.75;color:rgba(255,255,255,0.6);max-width:340px;margin-bottom:2.25rem;">
        {{ section.settings.body }}
      </p>
      <a href="{{ section.settings.btn_url }}" class="btn-outline-white">{{ section.settings.btn_label }}</a>
    </div>
  </div>

  <!-- Right: lifestyle image -->
  <div class="split-panel" style="position:relative;overflow:hidden;min-height:560px;">
    {%- if section.settings.image != blank -%}
      <img src="{{ section.settings.image | image_url: width: 900 }}"
        alt="{{ section.settings.image.alt | escape }}" class="split-img"
        style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;">
    {%- endif -%}
    <div style="position:absolute;inset:0;background:linear-gradient(to left,rgba(147,4,78,0.28) 0%,transparent 55%);pointer-events:none;"></div>
  </div>

</section>

{% schema %}
{
  "name": "Craft Split",
  "settings": [
    { "type": "text",         "id": "eyebrow",    "label": "Eyebrow",   "default": "The Craft" },
    { "type": "textarea",     "id": "heading",    "label": "Heading",   "default": "Actively\nAwesome\nAgave" },
    { "type": "textarea",     "id": "body",       "label": "Body copy", "default": "Sourced from the volcanic highlands of Jalisco. Slow-roasted in traditional brick ovens. 100% blue agave — no shortcuts, no compromises, ever." },
    { "type": "text",         "id": "btn_label",  "label": "Button label", "default": "Learn More" },
    { "type": "url",          "id": "btn_url",    "label": "Button URL" },
    { "type": "image_picker", "id": "image",      "label": "Right image" },
    { "type": "image_picker", "id": "watermark",  "label": "Watermark image (logo)" }
  ],
  "presets": [{ "name": "Craft Split" }]
}
{% endschema %}
