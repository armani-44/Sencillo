<style>
  .delivery-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .delivery-card { background: var(--cream); border-radius: 16px; padding: 2.25rem; }
  .faq-item { border-bottom: 1px solid rgba(0,0,0,0.07); }
  .faq-btn { width:100%; display:flex; align-items:center; justify-content:space-between; padding:1.25rem 0; background:none; border:none; cursor:pointer; font-family:'Jost',sans-serif; font-weight:700; font-size:0.88rem; letter-spacing:0.02em; color:var(--dark); text-align:left; gap:1rem; }
  .faq-chevron { flex-shrink:0; transition:transform 0.3s var(--ease-smooth); }
  .faq-body { display:none; padding-bottom:1.25rem; font-size:0.9rem; line-height:1.75; color:#666; }
  .faq-item.open .faq-chevron { transform:rotate(180deg); }
  .faq-item.open .faq-body { display:block; }
  @media (max-width:900px) { .delivery-grid { grid-template-columns:1fr !important; } }
  @media (max-width:640px) { .delivery-grid { grid-template-columns:1fr !important; } }
</style>

<!-- ── Hero ── -->
<section style="position:relative;overflow:hidden;min-height:420px;display:flex;align-items:center;background:var(--dark);">
  {%- if section.settings.hero_image != blank -%}
    <img src="{{ section.settings.hero_image | image_url: width: 1920 }}" alt="Delivery"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;opacity:0.35;">
  {%- endif -%}
  <div style="position:absolute;inset:0;background:linear-gradient(135deg,rgba(26,26,26,0.92) 0%,rgba(147,4,78,0.55) 100%);"></div>
  <div style="position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:5rem 3.5rem;">
    <p class="eyebrow reveal" style="color:var(--yellow);margin-bottom:1rem;">{{ section.settings.hero_eyebrow }}</p>
    <h1 class="display reveal" style="font-size:clamp(3rem,6vw,5.5rem);color:#fff;margin-bottom:1.25rem;">{{ section.settings.hero_heading | newline_to_br }}</h1>
    <p class="reveal" style="font-size:1rem;line-height:1.7;color:rgba(255,255,255,0.75);max-width:480px;">{{ section.settings.hero_body }}</p>
  </div>
</section>

<!-- ── Delivery options ── -->
<section style="padding:6rem 2rem;background:#fff;">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="reveal" style="text-align:center;margin-bottom:3.5rem;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:0.6rem;">{{ section.settings.options_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2rem,4vw,3rem);color:var(--dark);">{{ section.settings.options_heading }}</h2>
    </div>
    <div class="delivery-grid">

      <!-- Standard -->
      <div class="delivery-card reveal" style="transition-delay:0.05s;">
        <div style="width:52px;height:52px;background:linear-gradient(135deg,var(--dark),#444);border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.75"><rect x="2" y="7" width="20" height="14" rx="2"/><path d="M16 7V5a2 2 0 00-2-2h-4a2 2 0 00-2 2v2"/></svg>
        </div>
        <h3 style="font-weight:800;font-size:1rem;text-transform:uppercase;letter-spacing:-0.01em;color:var(--dark);margin-bottom:0.4rem;">{{ section.settings.tier_1_name }}</h3>
        <p style="font-weight:900;font-size:1.5rem;color:var(--pink);letter-spacing:-0.02em;margin-bottom:0.75rem;">{{ section.settings.tier_1_price }}</p>
        <p style="font-size:0.88rem;line-height:1.65;color:#666;margin-bottom:0.6rem;">{{ section.settings.tier_1_timing }}</p>
        <p style="font-size:0.82rem;color:#999;">{{ section.settings.tier_1_note }}</p>
      </div>

      <!-- Express -->
      <div class="delivery-card reveal" style="transition-delay:0.1s;border:2px solid var(--pink);position:relative;">
        <div style="position:absolute;top:-12px;left:50%;transform:translateX(-50%);background:var(--pink);padding:0.2rem 0.9rem;border-radius:20px;">
          <span style="font-weight:700;font-size:0.6rem;letter-spacing:0.14em;text-transform:uppercase;color:#fff;">Most Popular</span>
        </div>
        <div style="width:52px;height:52px;background:linear-gradient(135deg,var(--pink),var(--deep));border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.75"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
        </div>
        <h3 style="font-weight:800;font-size:1rem;text-transform:uppercase;letter-spacing:-0.01em;color:var(--dark);margin-bottom:0.4rem;">{{ section.settings.tier_2_name }}</h3>
        <p style="font-weight:900;font-size:1.5rem;color:var(--pink);letter-spacing:-0.02em;margin-bottom:0.75rem;">{{ section.settings.tier_2_price }}</p>
        <p style="font-size:0.88rem;line-height:1.65;color:#666;margin-bottom:0.6rem;">{{ section.settings.tier_2_timing }}</p>
        <p style="font-size:0.82rem;color:#999;">{{ section.settings.tier_2_note }}</p>
      </div>

      <!-- Next Day -->
      <div class="delivery-card reveal" style="transition-delay:0.15s;">
        <div style="width:52px;height:52px;background:linear-gradient(135deg,var(--orange),var(--yellow));border-radius:14px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="var(--dark)" stroke-width="1.75"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        </div>
        <h3 style="font-weight:800;font-size:1rem;text-transform:uppercase;letter-spacing:-0.01em;color:var(--dark);margin-bottom:0.4rem;">{{ section.settings.tier_3_name }}</h3>
        <p style="font-weight:900;font-size:1.5rem;color:var(--pink);letter-spacing:-0.02em;margin-bottom:0.75rem;">{{ section.settings.tier_3_price }}</p>
        <p style="font-size:0.88rem;line-height:1.65;color:#666;margin-bottom:0.6rem;">{{ section.settings.tier_3_timing }}</p>
        <p style="font-size:0.82rem;color:#999;">{{ section.settings.tier_3_note }}</p>
      </div>

    </div>

    <!-- Free delivery callout -->
    <div class="reveal" style="margin-top:2.5rem;background:linear-gradient(135deg,var(--pink),var(--deep));border-radius:16px;padding:2rem 2.5rem;display:flex;align-items:center;gap:1.5rem;flex-wrap:wrap;">
      <div style="width:48px;height:48px;background:rgba(255,255,255,0.15);border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="1.75"><path d="M20 12V22H4V12"/><path d="M22 7H2v5h20V7z"/><path d="M12 22V7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
      </div>
      <div>
        <p style="font-weight:900;font-size:1.1rem;color:#fff;letter-spacing:-0.01em;margin-bottom:0.2rem;">{{ section.settings.free_delivery_heading }}</p>
        <p style="font-size:0.88rem;color:rgba(255,255,255,0.8);">{{ section.settings.free_delivery_body }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ── Returns & Info ── -->
<section style="padding:5rem 2rem;background:var(--cream);">
  <div style="max-width:900px;margin:0 auto;">
    <div class="reveal" style="text-align:center;margin-bottom:3rem;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:0.6rem;">{{ section.settings.returns_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--dark);">{{ section.settings.returns_heading }}</h2>
    </div>
    <div style="background:#fff;border-radius:16px;padding:2.5rem;font-size:0.92rem;line-height:1.8;color:#555;" class="reveal">
      {{ section.settings.returns_body }}
    </div>
  </div>
</section>

<!-- ── FAQ ── -->
<section style="padding:5rem 2rem 7rem;background:#fff;">
  <div style="max-width:800px;margin:0 auto;">
    <div class="reveal" style="text-align:center;margin-bottom:3rem;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:0.6rem;">{{ section.settings.faq_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(1.8rem,3.5vw,2.8rem);color:var(--dark);">{{ section.settings.faq_heading }}</h2>
    </div>

    <div class="reveal">
      {%- for i in (1..5) -%}
        {%- assign q_key = 'faq_' | append: i | append: '_q' -%}
        {%- assign a_key = 'faq_' | append: i | append: '_a' -%}
        {%- if section.settings[q_key] != blank -%}
          <div class="faq-item">
            <button class="faq-btn" aria-expanded="false">
              <span>{{ section.settings[q_key] }}</span>
              <svg class="faq-chevron" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
            </button>
            <div class="faq-body">{{ section.settings[a_key] }}</div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    <!-- CTA -->
    <div class="reveal" style="text-align:center;margin-top:3.5rem;">
      <p style="font-size:0.9rem;color:#888;margin-bottom:1.25rem;">{{ section.settings.cta_text }}</p>
      <a href="{{ section.settings.cta_url | default: '/pages/contact' }}" class="btn-dark">{{ section.settings.cta_label }}</a>
    </div>
  </div>
</section>

<script>
(function() {
  document.querySelectorAll('.faq-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach(function(el) { el.classList.remove('open'); el.querySelector('.faq-btn').setAttribute('aria-expanded','false'); });
      if (!isOpen) { item.classList.add('open'); btn.setAttribute('aria-expanded','true'); }
    });
  });
})();
</script>

{% schema %}
{
  "name": "Delivery Page",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    { "type": "image_picker", "id": "hero_image", "label": "Hero background image" },
    { "type": "text",     "id": "hero_eyebrow", "label": "Eyebrow",  "default": "Shipping & Delivery" },
    { "type": "textarea", "id": "hero_heading",  "label": "Heading (new line = line break)", "default": "Fast.\nReliable.\nOn Us." },
    { "type": "textarea", "id": "hero_body",     "label": "Subheading", "default": "We know you can't wait to crack open a Sencillo. Here's everything you need to know about getting it to your door." },
    {
      "type": "header",
      "content": "Delivery Options"
    },
    { "type": "text", "id": "options_eyebrow", "label": "Eyebrow",  "default": "Delivery Options" },
    { "type": "text", "id": "options_heading",  "label": "Heading",  "default": "Choose Your Speed" },
    { "type": "text", "id": "tier_1_name",    "label": "Option 1 — Name",   "default": "Standard" },
    { "type": "text", "id": "tier_1_price",   "label": "Option 1 — Price",  "default": "FREE over £30" },
    { "type": "text", "id": "tier_1_timing",  "label": "Option 1 — Timing", "default": "3–5 working days" },
    { "type": "text", "id": "tier_1_note",    "label": "Option 1 — Note",   "default": "£3.99 for orders under £30" },
    { "type": "text", "id": "tier_2_name",    "label": "Option 2 — Name",   "default": "Express" },
    { "type": "text", "id": "tier_2_price",   "label": "Option 2 — Price",  "default": "£5.99" },
    { "type": "text", "id": "tier_2_timing",  "label": "Option 2 — Timing", "default": "1–2 working days" },
    { "type": "text", "id": "tier_2_note",    "label": "Option 2 — Note",   "default": "Order by 2pm for next-working-day dispatch" },
    { "type": "text", "id": "tier_3_name",    "label": "Option 3 — Name",   "default": "Next Day" },
    { "type": "text", "id": "tier_3_price",   "label": "Option 3 — Price",  "default": "£8.99" },
    { "type": "text", "id": "tier_3_timing",  "label": "Option 3 — Timing", "default": "Next working day" },
    { "type": "text", "id": "tier_3_note",    "label": "Option 3 — Note",   "default": "Order by 12pm. Monday–Friday only." },
    { "type": "text",     "id": "free_delivery_heading", "label": "Free delivery callout — Heading", "default": "Free delivery on all orders over £30" },
    { "type": "textarea", "id": "free_delivery_body",    "label": "Free delivery callout — Body",    "default": "Stock up, save on shipping, and enjoy more Sencillo for your money." },
    {
      "type": "header",
      "content": "Returns & Exchanges"
    },
    { "type": "text",     "id": "returns_eyebrow", "label": "Eyebrow", "default": "No Fuss" },
    { "type": "text",     "id": "returns_heading",  "label": "Heading", "default": "Returns Policy" },
    { "type": "richtext", "id": "returns_body", "label": "Returns body text (rich text)",
      "default": "<p>If your order arrives damaged or incorrect, we'll make it right — no questions asked. Simply contact us within 14 days of delivery and we'll arrange a replacement or full refund.<\/p><p>As our products are perishable beverages, we're unable to accept returns of opened or undamaged goods. If you change your mind on an unopened order, please get in touch within 24 hours of placing it and we'll do our best to help.<\/p><p>Refunds are processed within 3–5 working days of us receiving confirmation.<\/p>" },
    {
      "type": "header",
      "content": "FAQ"
    },
    { "type": "text", "id": "faq_eyebrow", "label": "Eyebrow", "default": "Got Questions?" },
    { "type": "text", "id": "faq_heading",  "label": "Heading", "default": "FAQ" },
    { "type": "text",     "id": "faq_1_q", "label": "Question 1", "default": "When will my order be dispatched?" },
    { "type": "textarea", "id": "faq_1_a", "label": "Answer 1",   "default": "Orders placed before 2pm on a working day are dispatched the same day. Orders placed after 2pm or on weekends are dispatched the next working day." },
    { "type": "text",     "id": "faq_2_q", "label": "Question 2", "default": "Do you deliver on weekends?" },
    { "type": "textarea", "id": "faq_2_a", "label": "Answer 2",   "default": "Standard and Express deliveries may arrive on Saturdays depending on your carrier. Next Day delivery operates Monday–Friday only." },
    { "type": "text",     "id": "faq_3_q", "label": "Question 3", "default": "Can I track my order?" },
    { "type": "textarea", "id": "faq_3_a", "label": "Answer 3",   "default": "Yes — you'll receive a tracking link via email as soon as your order leaves our warehouse." },
    { "type": "text",     "id": "faq_4_q", "label": "Question 4", "default": "Do you ship outside the UK?" },
    { "type": "textarea", "id": "faq_4_a", "label": "Answer 4",   "default": "We currently ship within the UK only. International shipping is coming soon — sign up to La Familia to be the first to know." },
    { "type": "text",     "id": "faq_5_q", "label": "Question 5", "default": "What if I'm not home when my order arrives?" },
    { "type": "textarea", "id": "faq_5_a", "label": "Answer 5",   "default": "Your carrier will leave a card with redelivery or collection options. Most carriers will also attempt a neighbour drop if you've authorised this at checkout." },
    {
      "type": "header",
      "content": "Bottom CTA"
    },
    { "type": "textarea", "id": "cta_text",  "label": "Text above button", "default": "Still have questions? Our team is happy to help." },
    { "type": "text",     "id": "cta_label", "label": "Button label",      "default": "Contact Us" },
    { "type": "url",      "id": "cta_url",   "label": "Button link" }
  ],
  "presets": [{ "name": "Delivery Page" }]
}
{% endschema %}
