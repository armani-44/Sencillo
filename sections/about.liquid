<style>
  .about-split { display: grid; grid-template-columns: 1fr 1fr; gap: 5rem; align-items: center; }
  .craft-split { display: grid; grid-template-columns: 1fr 1fr; }
  .values-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 1.5rem; }
  .about-value-card { background: var(--cream); border-radius: 14px; padding: 2.25rem; transition: transform 0.28s var(--ease-spring), box-shadow 0.28s; }
  .about-value-card:hover { transform: translateY(-5px); box-shadow: 0 20px 44px rgba(0,0,0,0.07); }
  @media (max-width: 900px) {
    .about-split { grid-template-columns: 1fr !important; gap: 2.5rem !important; }
    .craft-split { grid-template-columns: 1fr !important; }
    .values-grid { grid-template-columns: 1fr !important; }
  }
</style>

<!-- ══ HERO ══ -->
<section style="position:relative;overflow:hidden;min-height:560px;display:flex;align-items:center;">
  {%- if section.settings.hero_image != blank -%}
    <img src="{{ section.settings.hero_image | image_url: width: 1920 }}" alt="Sencillo story"
      style="position:absolute;inset:0;width:100%;height:100%;object-fit:cover;object-position:center;">
  {%- else -%}
    <div style="position:absolute;inset:0;background:var(--deep);"></div>
  {%- endif -%}
  <div style="position:absolute;inset:0;background:linear-gradient(145deg,rgba(147,4,78,0.85) 0%,rgba(225,0,114,0.65) 50%,rgba(255,84,66,0.4) 100%);"></div>
  {%- if section.settings.logo_watermark != blank -%}
    <div style="position:absolute;right:-5%;bottom:-10%;width:55%;opacity:0.06;filter:brightness(0) invert(1);pointer-events:none;">
      <img src="{{ section.settings.logo_watermark | image_url: width: 800 }}" alt="" style="width:100%;height:auto;">
    </div>
  {%- endif -%}
  <div style="position:relative;z-index:2;max-width:1280px;margin:0 auto;padding:5rem 3.5rem;">
    <p class="eyebrow reveal" style="color:rgba(255,255,255,0.65);margin-bottom:1.25rem;">{{ section.settings.hero_eyebrow }}</p>
    <h1 class="display reveal" style="font-size:clamp(3.5rem,7vw,6rem);color:#fff;margin-bottom:1.75rem;">
      {{ section.settings.hero_heading | newline_to_br }}
    </h1>
    <p class="reveal" style="font-weight:400;font-size:1.05rem;line-height:1.72;color:rgba(255,255,255,0.82);max-width:480px;">
      {{ section.settings.hero_body }}
    </p>
  </div>
</section>

<!-- ══ ORIGIN STORY ══ -->
<section style="padding:7rem 2rem;background:#fff;">
  <div style="max-width:1100px;margin:0 auto;" class="about-split">
    <div class="reveal">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:1rem;">{{ section.settings.origin_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.4rem,5vw,3.8rem);color:var(--dark);margin-bottom:2rem;">{{ section.settings.origin_heading | newline_to_br }}</h2>
      <div style="width:40px;height:3px;background:var(--pink);margin-bottom:2rem;border-radius:2px;"></div>
      <div style="font-weight:400;font-size:0.95rem;line-height:1.8;color:#666;">
        {{ section.settings.origin_body }}
      </div>
    </div>
    <div class="reveal" style="transition-delay:0.12s;">
      <div style="border-radius:16px;overflow:hidden;aspect-ratio:3/4;position:relative;">
        {%- if section.settings.origin_image != blank -%}
          <img src="{{ section.settings.origin_image | image_url: width: 900 }}" alt="Sencillo lifestyle"
            style="width:100%;height:100%;object-fit:cover;object-position:center 18%;transition:transform 0.6s var(--ease-smooth);"
            onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
        {%- else -%}
          <div style="width:100%;height:100%;background:linear-gradient(145deg,var(--pink),var(--deep));"></div>
        {%- endif -%}
        <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(147,4,78,0.3) 0%,transparent 50%);"></div>
      </div>
    </div>
  </div>
</section>

<!-- ══ VALUES ══ -->
<section style="padding:6rem 2rem;background:var(--cream);">
  <div style="max-width:1100px;margin:0 auto;">
    <div class="reveal" style="text-align:center;margin-bottom:4rem;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:0.75rem;">{{ section.settings.values_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.2rem,4.5vw,3.2rem);color:var(--dark);">{{ section.settings.values_heading | newline_to_br }}</h2>
    </div>
    <div class="values-grid">
      <div class="about-value-card reveal" style="transition-delay:0.06s;">
        <div style="width:48px;height:48px;background:linear-gradient(135deg,var(--pink),var(--deep));border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <span style="font-size:1.4rem;">{{ section.settings.value_1_emoji }}</span>
        </div>
        <h3 style="font-weight:800;font-size:1.05rem;letter-spacing:-0.01em;text-transform:uppercase;color:var(--dark);margin-bottom:0.75rem;">{{ section.settings.value_1_title }}</h3>
        <p style="font-weight:400;font-size:0.88rem;line-height:1.72;color:#777;">{{ section.settings.value_1_body }}</p>
      </div>
      <div class="about-value-card reveal" style="transition-delay:0.12s;">
        <div style="width:48px;height:48px;background:linear-gradient(135deg,var(--orange),var(--yellow));border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <span style="font-size:1.4rem;">{{ section.settings.value_2_emoji }}</span>
        </div>
        <h3 style="font-weight:800;font-size:1.05rem;letter-spacing:-0.01em;text-transform:uppercase;color:var(--dark);margin-bottom:0.75rem;">{{ section.settings.value_2_title }}</h3>
        <p style="font-weight:400;font-size:0.88rem;line-height:1.72;color:#777;">{{ section.settings.value_2_body }}</p>
      </div>
      <div class="about-value-card reveal" style="transition-delay:0.18s;">
        <div style="width:48px;height:48px;background:linear-gradient(135deg,var(--coral),var(--orange));border-radius:12px;display:flex;align-items:center;justify-content:center;margin-bottom:1.5rem;">
          <span style="font-size:1.4rem;">{{ section.settings.value_3_emoji }}</span>
        </div>
        <h3 style="font-weight:800;font-size:1.05rem;letter-spacing:-0.01em;text-transform:uppercase;color:var(--dark);margin-bottom:0.75rem;">{{ section.settings.value_3_title }}</h3>
        <p style="font-weight:400;font-size:0.88rem;line-height:1.72;color:#777;">{{ section.settings.value_3_body }}</p>
      </div>
    </div>
  </div>
</section>

<!-- ══ THE CRAFT ══ -->
<section class="craft-split">
  <div style="position:relative;overflow:hidden;min-height:560px;">
    {%- if section.settings.craft_image != blank -%}
      <img src="{{ section.settings.craft_image | image_url: width: 1200 }}" alt="Sencillo can collection"
        style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;transition:transform 0.8s var(--ease-smooth);"
        onmouseover="this.style.transform='scale(1.04)'" onmouseout="this.style.transform='scale(1)'">
    {%- else -%}
      <div style="width:100%;height:100%;min-height:560px;background:linear-gradient(145deg,var(--orange),var(--yellow));"></div>
    {%- endif -%}
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(147,4,78,0.2) 0%,transparent 60%);"></div>
  </div>
  <div style="background:var(--deep);display:flex;align-items:center;justify-content:center;padding:5rem 4.5rem;">
    <div class="reveal">
      <p class="eyebrow" style="color:var(--yellow);margin-bottom:1.3rem;">{{ section.settings.craft_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.5rem,4.5vw,3.8rem);color:#fff;margin-bottom:0.5rem;">
        {{ section.settings.craft_heading | newline_to_br }}
      </h2>
      <div style="width:40px;height:3px;background:var(--pink);margin:1.75rem 0;border-radius:2px;"></div>
      <div style="font-weight:400;font-size:0.95rem;line-height:1.75;color:rgba(255,255,255,0.62);max-width:340px;margin-bottom:2rem;">
        {{ section.settings.craft_body }}
      </div>
      <a href="{{ routes.root_url }}collections/all" class="btn-outline-white">Shop The Range</a>
    </div>
  </div>
</section>

<!-- ══ FOUNDERS ══ -->
<section style="padding:7rem 2rem;background:#fff;">
  <div style="max-width:900px;margin:0 auto;text-align:center;">
    <div class="reveal">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:1rem;">{{ section.settings.founders_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.4rem,5vw,3.8rem);color:var(--dark);margin-bottom:2.5rem;">{{ section.settings.founders_heading | newline_to_br }}</h2>
      <p style="font-weight:400;font-size:0.95rem;line-height:1.82;color:#666;max-width:620px;margin:0 auto 3rem;">
        {{ section.settings.founders_body }}
      </p>
      <p style="font-weight:700;font-size:0.95rem;line-height:1.72;color:var(--dark);max-width:500px;margin:0 auto 3rem;font-style:italic;">
        "{{ section.settings.founders_quote }}"
      </p>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr;gap:2rem;max-width:600px;margin:0 auto;" class="reveal">
      <div style="border-radius:14px;overflow:hidden;position:relative;aspect-ratio:3/4;background:linear-gradient(145deg,var(--pink),var(--deep));">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;">
          <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.15);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1.5rem;">☀️</div>
          <p style="font-weight:900;font-size:1.1rem;text-transform:uppercase;letter-spacing:-0.01em;color:#fff;margin-bottom:0.3rem;">Co-Founder</p>
          <p style="font-weight:300;font-size:0.85rem;color:rgba(255,255,255,0.7);font-style:italic;">Vision &amp; Brand</p>
        </div>
      </div>
      <div style="border-radius:14px;overflow:hidden;position:relative;aspect-ratio:3/4;background:linear-gradient(145deg,var(--orange),var(--yellow));">
        <div style="position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:2rem;text-align:center;">
          <div style="width:60px;height:60px;border-radius:50%;background:rgba(255,255,255,0.2);display:flex;align-items:center;justify-content:center;margin-bottom:1rem;font-size:1.5rem;">🌵</div>
          <p style="font-weight:900;font-size:1.1rem;text-transform:uppercase;letter-spacing:-0.01em;color:var(--dark);margin-bottom:0.3rem;">Co-Founder</p>
          <p style="font-weight:300;font-size:0.85rem;color:rgba(0,0,0,0.55);font-style:italic;">Product &amp; Craft</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ══ CTA BAND ══ -->
<section style="background:var(--pink);padding:5.5rem 2rem;text-align:center;position:relative;overflow:hidden;">
  {%- if section.settings.logo_watermark != blank -%}
    <div style="position:absolute;right:-5%;top:50%;transform:translateY(-50%);width:45%;opacity:0.06;filter:brightness(0) invert(1);pointer-events:none;">
      <img src="{{ section.settings.logo_watermark | image_url: width: 600 }}" alt="" style="width:100%;height:auto;">
    </div>
  {%- endif -%}
  <div class="reveal" style="position:relative;z-index:2;">
    <p class="eyebrow" style="color:rgba(255,255,255,0.62);margin-bottom:1rem;">{{ section.settings.cta_eyebrow }}</p>
    <h2 class="display" style="font-size:clamp(2.8rem,6vw,5rem);color:#fff;margin-bottom:2rem;">{{ section.settings.cta_heading | newline_to_br }}</h2>
    <div style="display:flex;gap:1rem;justify-content:center;flex-wrap:wrap;">
      <a href="{{ routes.root_url }}collections/all" style="display:inline-block;background:#fff;color:var(--pink);font-weight:700;font-size:0.72rem;letter-spacing:0.16em;text-transform:uppercase;padding:0.95rem 2.2rem;border-radius:9999px;text-decoration:none;transition:background 0.2s,transform 0.22s var(--ease-spring);" onmouseover="this.style.background='var(--yellow)';this.style.color='var(--dark)'" onmouseout="this.style.background='#fff';this.style.color='var(--pink)'">Shop Now</a>
      <a href="#newsletter" class="btn-outline-white">Join La Familia</a>
    </div>
  </div>
</section>

<script>
  (function() {
    var io = new IntersectionObserver(function(entries) {
      entries.forEach(function(e) { if (e.isIntersecting) { e.target.classList.add('in'); io.unobserve(e.target); } });
    }, { threshold: 0.1 });
    document.querySelectorAll('.reveal').forEach(function(el) { io.observe(el); });
  })();
</script>

{% schema %}
{
  "name": "About Page",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    { "type": "image_picker", "id": "hero_image",      "label": "Hero background image" },
    { "type": "image_picker", "id": "origin_image",    "label": "Origin story image" },
    { "type": "image_picker", "id": "craft_image",     "label": "Craft section image" },
    { "type": "image_picker", "id": "logo_watermark",  "label": "Logo (for watermark overlays)" },
    {
      "type": "header",
      "content": "Hero Section"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Eyebrow label",
      "default": "Our Story"
    },
    {
      "type": "textarea",
      "id": "hero_heading",
      "label": "Heading (new line = line break)",
      "default": "Simple By\nDesign."
    },
    {
      "type": "textarea",
      "id": "hero_body",
      "label": "Body text",
      "default": "Sencillo was born from a simple idea: the best cocktail you ever tasted shouldn't require a bartender, a shaker, or a ten-step recipe. Just great ingredients and great moments."
    },
    {
      "type": "header",
      "content": "Origin Story Section"
    },
    {
      "type": "text",
      "id": "origin_eyebrow",
      "label": "Eyebrow label",
      "default": "Where It Began"
    },
    {
      "type": "textarea",
      "id": "origin_heading",
      "label": "Heading (new line = line break)",
      "default": "Jalisco\nMeets\nLondon"
    },
    {
      "type": "richtext",
      "id": "origin_body",
      "label": "Body text (supports paragraphs)",
      "default": "<p>Sencillo was born on a rooftop in Mexico City, over a round of tequila so good it felt like cheating. Two friends asked themselves: why isn't this in a can? Why is premium tequila locked behind a bar?</p><p>Two years later, back in London with a mission and a distillery partner in the highlands of Jalisco, Sencillo launched. The name means <em>simple<\/em> in Spanish — and that's exactly what it is.<\/p><p>Simple ingredients. Simple format. Unapologetically bold flavour. That's Sencillo.<\/p>"
    },
    {
      "type": "header",
      "content": "Values Section"
    },
    {
      "type": "text",
      "id": "values_eyebrow",
      "label": "Eyebrow label",
      "default": "What We Stand For"
    },
    {
      "type": "textarea",
      "id": "values_heading",
      "label": "Heading (new line = line break)",
      "default": "No Fuss.\nNo Compromise."
    },
    {
      "type": "text",
      "id": "value_1_emoji",
      "label": "Card 1 — Icon (emoji)",
      "default": "🌵"
    },
    {
      "type": "text",
      "id": "value_1_title",
      "label": "Card 1 — Title",
      "default": "100% Blue Agave"
    },
    {
      "type": "textarea",
      "id": "value_1_body",
      "label": "Card 1 — Body",
      "default": "We use only the finest 100% blue agave tequila from Jalisco's volcanic highlands. No blended spirit. No shortcuts. Ever."
    },
    {
      "type": "text",
      "id": "value_2_emoji",
      "label": "Card 2 — Icon (emoji)",
      "default": "🍋"
    },
    {
      "type": "text",
      "id": "value_2_title",
      "label": "Card 2 — Title",
      "default": "Real Ingredients"
    },
    {
      "type": "textarea",
      "id": "value_2_body",
      "label": "Card 2 — Body",
      "default": "Strawberries. Rhubarb. Pineapple. Ginger. Real fruit. Real flavour. Nothing artificial, nothing that doesn't belong."
    },
    {
      "type": "text",
      "id": "value_3_emoji",
      "label": "Card 3 — Icon (emoji)",
      "default": "♻️"
    },
    {
      "type": "text",
      "id": "value_3_title",
      "label": "Card 3 — Title",
      "default": "Sustainable"
    },
    {
      "type": "textarea",
      "id": "value_3_body",
      "label": "Card 3 — Body",
      "default": "Our cans are 100% recyclable. Our packaging is minimal by design. We believe luxury and responsibility belong together."
    },
    {
      "type": "header",
      "content": "The Craft Section"
    },
    {
      "type": "text",
      "id": "craft_eyebrow",
      "label": "Eyebrow label",
      "default": "From Jalisco, With Love"
    },
    {
      "type": "textarea",
      "id": "craft_heading",
      "label": "Heading (new line = line break)",
      "default": "Actively\nAwesome\nAgave"
    },
    {
      "type": "richtext",
      "id": "craft_body",
      "label": "Body text (supports paragraphs)",
      "default": "<p>The agave plants we use take 7–10 years to mature in the mineral-rich volcanic soil of the Jalisco highlands. The piñas are slow-roasted in traditional brick ovens.<\/p><p>Double distilled in copper pot stills. Then blended with our carefully sourced fruit ingredients and canned at the peak of flavour. That's how Sencillo is made — the right way.<\/p>"
    },
    {
      "type": "header",
      "content": "Founders Section"
    },
    {
      "type": "text",
      "id": "founders_eyebrow",
      "label": "Eyebrow label",
      "default": "The People Behind It"
    },
    {
      "type": "textarea",
      "id": "founders_heading",
      "label": "Heading (new line = line break)",
      "default": "Built By\nBelievers"
    },
    {
      "type": "textarea",
      "id": "founders_body",
      "label": "Body text",
      "default": "Sencillo was founded by two friends who believe that what you drink says something about who you are. Not your status — your taste. Your sense of adventure. Your refusal to settle for average."
    },
    {
      "type": "textarea",
      "id": "founders_quote",
      "label": "Pull quote (shown in italics, quotes added automatically)",
      "default": "We wanted to make the world's best canned tequila cocktail. We think we did. You tell us."
    },
    {
      "type": "header",
      "content": "CTA Band"
    },
    {
      "type": "text",
      "id": "cta_eyebrow",
      "label": "Eyebrow label",
      "default": "Ready?"
    },
    {
      "type": "textarea",
      "id": "cta_heading",
      "label": "Heading (new line = line break)",
      "default": "Taste The\nDifference."
    }
  ],
  "presets": [{ "name": "About Page" }]
}
{% endschema %}
