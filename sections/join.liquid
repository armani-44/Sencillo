<!-- ─── Join Hero ─── -->
<section style="background:var(--yellow);padding:6rem 2rem 5rem;text-align:center;position:relative;overflow:hidden;">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 30% 60%,rgba(225,0,114,0.12) 0%,transparent 65%);pointer-events:none;"></div>
  <!-- Watermark -->
  <div style="position:absolute;right:-5%;bottom:-10%;width:40%;opacity:0.07;pointer-events:none;transform:rotate(-8deg);">
    {%- if section.settings.watermark != blank -%}
      <img src="{{ section.settings.watermark | image_url: width: 500 }}" alt="" style="width:100%;height:auto;">
    {%- endif -%}
  </div>
  <div class="reveal" style="position:relative;z-index:1;max-width:700px;margin:0 auto;">
    <p class="eyebrow" style="color:var(--deep);margin-bottom:1.25rem;">{{ section.settings.eyebrow }}</p>
    <h1 class="display" style="font-size:clamp(3.6rem,9vw,7rem);color:var(--dark);margin-bottom:1.5rem;line-height:0.95;">
      {{ section.settings.heading | newline_to_br }}
    </h1>
    <p style="font-size:1.05rem;line-height:1.75;color:rgba(0,0,0,0.65);max-width:500px;margin:0 auto;">
      {{ section.settings.subheading }}
    </p>
  </div>
</section>

<!-- ─── Perks Strip ─── -->
<section style="background:var(--deep);padding:3.5rem 2rem;" class="grainy">
  <div style="max-width:1000px;margin:0 auto;display:grid;grid-template-columns:repeat(3,1fr);gap:2rem;text-align:center;">
    {%- assign perk_icons = '🥃,🎉,🚀' | split: ',' -%}
    {%- for i in (1..3) -%}
      {%- assign title_key = 'perk_' | append: i | append: '_title' -%}
      {%- assign body_key  = 'perk_' | append: i | append: '_body'  -%}
      <div class="reveal" style="padding:0.5rem;">
        <p style="font-size:2rem;margin-bottom:0.75rem;">{{ perk_icons[forloop.index0] }}</p>
        <p style="font-weight:800;font-size:0.82rem;letter-spacing:0.15em;text-transform:uppercase;color:#fff;margin-bottom:0.5rem;">{{ section.settings[title_key] }}</p>
        <p style="font-size:0.88rem;line-height:1.7;color:rgba(255,255,255,0.55);">{{ section.settings[body_key] }}</p>
      </div>
    {%- endfor -%}
  </div>
</section>

<!-- ─── Sign-Up Form ─── -->
<section style="background:var(--cream);padding:6rem 2rem;">
  <div style="max-width:680px;margin:0 auto;text-align:center;">
    <div class="reveal">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:1.25rem;">{{ section.settings.form_eyebrow }}</p>
      <h2 class="display" style="font-size:clamp(2.4rem,5vw,3.8rem);color:var(--dark);margin-bottom:1rem;">
        {{ section.settings.form_heading | newline_to_br }}
      </h2>
      <p style="font-size:0.95rem;line-height:1.75;color:#666;max-width:480px;margin:0 auto 3rem;">
        {{ section.settings.form_body }}
      </p>

      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">

        {%- if form.posted_successfully? -%}
          <div style="background:#fff;border-radius:20px;padding:3rem;box-shadow:0 4px 6px rgba(0,0,0,0.04),0 20px 60px rgba(0,0,0,0.07);margin-bottom:1.5rem;">
            <div style="width:64px;height:64px;background:var(--pink);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
              <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
            </div>
            <h3 class="display" style="font-size:2rem;color:var(--dark);margin-bottom:1rem;">You're In!</h3>
            <p style="color:#666;font-size:0.95rem;line-height:1.7;">{{ section.settings.success_message }}</p>
          </div>
        {%- else -%}
          <!-- Name row -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:1rem;">
            <input type="text" name="contact[first_name]" placeholder="First name"
              style="padding:1rem 1.25rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
            <input type="text" name="contact[last_name]" placeholder="Last name"
              style="padding:1rem 1.25rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
          </div>

          <!-- Email + submit pill -->
          <div style="display:flex;border-radius:9999px;overflow:hidden;box-shadow:0 4px 24px rgba(0,0,0,0.1);margin-bottom:1rem;">
            <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}" required
              style="flex:1;padding:1.15rem 1.8rem;font-family:'Jost',sans-serif;font-weight:400;font-size:0.95rem;border:none;outline:none;background:#fff;color:var(--dark);min-width:0;">
            <button type="submit"
              style="background:var(--pink);color:#fff;font-family:'Jost',sans-serif;font-weight:700;font-size:0.7rem;letter-spacing:0.17em;text-transform:uppercase;padding:1.15rem 2rem;border:none;cursor:pointer;white-space:nowrap;transition:background 0.2s;"
              onmouseover="this.style.background='var(--deep)'" onmouseout="this.style.background='var(--pink)'">
              {{ section.settings.btn_label }}
            </button>
          </div>
        {%- endif -%}

        {%- if form.errors -%}
          <p style="color:var(--pink);font-size:0.85rem;margin-top:0.5rem;">{{ form.errors | default_errors }}</p>
        {%- endif -%}
      {% endform %}

      <p style="font-size:0.78rem;color:rgba(0,0,0,0.4);letter-spacing:0.02em;margin-top:1rem;">{{ section.settings.disclaimer }}</p>
    </div>
  </div>
</section>

<!-- ─── Social Proof / Quote ─── -->
<section style="background:var(--pink);padding:5rem 2rem;text-align:center;position:relative;overflow:hidden;" class="grainy">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 70% 30%,rgba(255,255,255,0.08) 0%,transparent 65%);pointer-events:none;"></div>
  <div class="reveal" style="position:relative;z-index:1;max-width:700px;margin:0 auto;">
    <p style="font-size:clamp(1.4rem,3vw,2.2rem);font-weight:800;line-height:1.35;color:#fff;letter-spacing:-0.02em;margin-bottom:1.5rem;font-style:italic;">
      "{{ section.settings.quote }}"
    </p>
    <p class="eyebrow" style="color:rgba(255,255,255,0.6);">{{ section.settings.quote_attr }}</p>
  </div>
</section>

<style>
  @media (max-width: 640px) {
    .join-perks { grid-template-columns: 1fr !important; }
    .join-name-row { grid-template-columns: 1fr !important; }
  }
</style>

{% schema %}
{
  "name": "Join La Familia",
  "settings": [
    { "type": "header",       "content": "Hero" },
    { "type": "image_picker", "id": "watermark",       "label": "Watermark logo" },
    { "type": "text",         "id": "eyebrow",          "label": "Eyebrow",           "default": "Join La Familia" },
    { "type": "textarea",     "id": "heading",          "label": "Heading",           "default": "Be\nFirst\nIn Line" },
    { "type": "text",         "id": "subheading",       "label": "Subheading",        "default": "New drops, exclusive deals, and tequila news — straight to your inbox. No spam, ever." },
    { "type": "header",       "content": "Perks" },
    { "type": "text",         "id": "perk_1_title",     "label": "Perk 1 title",      "default": "Early Access" },
    { "type": "text",         "id": "perk_1_body",      "label": "Perk 1 body",       "default": "Be the first to know about new flavours and limited drops before anyone else." },
    { "type": "text",         "id": "perk_2_title",     "label": "Perk 2 title",      "default": "Exclusive Offers" },
    { "type": "text",         "id": "perk_2_body",      "label": "Perk 2 body",       "default": "Members-only discounts and bundles that never go public." },
    { "type": "text",         "id": "perk_3_title",     "label": "Perk 3 title",      "default": "Behind The Scenes" },
    { "type": "text",         "id": "perk_3_body",      "label": "Perk 3 body",       "default": "Stories from the agave fields, distillery visits, and cocktail recipes delivered monthly." },
    { "type": "header",       "content": "Sign-Up Form" },
    { "type": "text",         "id": "form_eyebrow",     "label": "Form eyebrow",      "default": "Never Miss A Drop" },
    { "type": "textarea",     "id": "form_heading",     "label": "Form heading",      "default": "Subscribe\nToday" },
    { "type": "textarea",     "id": "form_body",        "label": "Form body",         "default": "Join thousands of tequila lovers who already get the inside scoop on everything Sencillo." },
    { "type": "text",         "id": "placeholder",      "label": "Email placeholder", "default": "Enter your email address" },
    { "type": "text",         "id": "btn_label",        "label": "Button label",      "default": "Join Now" },
    { "type": "text",         "id": "disclaimer",       "label": "Disclaimer",        "default": "No spam, ever. Unsubscribe anytime. Your data is safe with us." },
    { "type": "text",         "id": "success_message",  "label": "Success message",   "default": "Welcome to La Familia! Keep an eye on your inbox for your first exclusive update." },
    { "type": "header",       "content": "Quote" },
    { "type": "textarea",     "id": "quote",            "label": "Quote text",        "default": "Life's too short for complicated cocktails — Sencillo keeps it bold, keeps it simple." },
    { "type": "text",         "id": "quote_attr",       "label": "Quote attribution", "default": "— The Sencillo Team" }
  ],
  "presets": [{ "name": "Join La Familia" }]
}
{% endschema %}
