<!-- ─── Contact Hero ─── -->
<section style="background:var(--deep);padding:5rem 2rem 4rem;text-align:center;position:relative;overflow:hidden;" class="grainy">
  <div style="position:absolute;inset:0;background:radial-gradient(ellipse at 60% 40%,rgba(225,0,114,0.18) 0%,transparent 65%);pointer-events:none;"></div>
  <div class="reveal" style="position:relative;z-index:1;max-width:660px;margin:0 auto;">
    <p class="eyebrow" style="color:var(--yellow);margin-bottom:1.25rem;">{{ section.settings.eyebrow }}</p>
    <h1 class="display" style="font-size:clamp(3.2rem,8vw,6rem);color:#fff;margin-bottom:1.5rem;text-shadow:0 4px 32px rgba(0,0,0,0.2);">
      {{ section.settings.heading | newline_to_br }}
    </h1>
    <p style="font-size:1rem;line-height:1.75;color:rgba(255,255,255,0.7);max-width:480px;margin:0 auto;">
      {{ section.settings.subheading }}
    </p>
  </div>
</section>

<!-- ─── Contact Body ─── -->
<section style="background:var(--cream);padding:5rem 2rem;">
  <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:1fr 1.6fr;gap:5rem;align-items:start;">

    <!-- Left: details -->
    <div class="reveal" style="padding-top:0.5rem;">
      <p class="eyebrow" style="color:var(--pink);margin-bottom:1.25rem;">Get In Touch</p>
      <h2 class="display" style="font-size:clamp(2rem,3.5vw,2.8rem);color:var(--dark);margin-bottom:1.5rem;line-height:1.05;">
        {{ section.settings.details_heading | newline_to_br }}
      </h2>
      <div style="width:44px;height:3px;background:var(--pink);border-radius:2px;margin-bottom:2rem;"></div>
      <p style="font-size:0.95rem;line-height:1.8;color:#555;margin-bottom:2.5rem;">
        {{ section.settings.details_body }}
      </p>

      <!-- Contact details list -->
      <div style="display:flex;flex-direction:column;gap:1.25rem;">
        {%- if section.settings.phone != blank -%}
        <div style="display:flex;align-items:center;gap:1rem;">
          <div style="width:42px;height:42px;background:var(--pink);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 11a19.79 19.79 0 01-3-8.59A2 2 0 012.06 0h3a2 2 0 012 1.72c.127.96.361 1.903.7 2.81a2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0122 16.92z"/></svg>
          </div>
          <div>
            <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--pink);margin-bottom:0.2rem;">Phone</p>
            <p style="font-size:0.95rem;font-weight:500;color:var(--dark);">{{ section.settings.phone }}</p>
          </div>
        </div>
        {%- endif -%}

        {%- if section.settings.email != blank -%}
        <div style="display:flex;align-items:center;gap:1rem;">
          <div style="width:42px;height:42px;background:var(--deep);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:var(--deep);margin-bottom:0.2rem;">Email</p>
            <a href="mailto:{{ section.settings.email }}" style="font-size:0.95rem;font-weight:500;color:var(--dark);text-decoration:none;border-bottom:1px solid rgba(0,0,0,0.15);padding-bottom:1px;transition:color 0.2s;border-color:var(--pink);"
              onmouseover="this.style.color='var(--pink)'" onmouseout="this.style.color='var(--dark)'">
              {{ section.settings.email }}
            </a>
          </div>
        </div>
        {%- endif -%}

        {%- if section.settings.location != blank -%}
        <div style="display:flex;align-items:center;gap:1rem;">
          <div style="width:42px;height:42px;background:var(--yellow);border-radius:50%;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--dark)" stroke-width="2.2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <p style="font-size:0.7rem;font-weight:700;letter-spacing:0.15em;text-transform:uppercase;color:#999;margin-bottom:0.2rem;">Location</p>
            <p style="font-size:0.95rem;font-weight:500;color:var(--dark);">{{ section.settings.location }}</p>
          </div>
        </div>
        {%- endif -%}
      </div>
    </div>

    <!-- Right: form card -->
    <div class="reveal" style="background:#fff;border-radius:20px;padding:3rem;box-shadow:0 4px 6px rgba(0,0,0,0.04),0 20px 60px rgba(0,0,0,0.07);">
      {%- if form.posted_successfully? -%}
        <div style="text-align:center;padding:3rem 1rem;">
          <div style="width:64px;height:64px;background:var(--pink);border-radius:50%;display:flex;align-items:center;justify-content:center;margin:0 auto 1.5rem;">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <h3 class="display" style="font-size:2rem;color:var(--dark);margin-bottom:1rem;">Message Sent!</h3>
          <p style="color:#666;font-size:0.95rem;line-height:1.7;">{{ section.settings.success_message }}</p>
        </div>
      {%- else -%}
        <p class="eyebrow" style="color:var(--pink);margin-bottom:1.5rem;">Send Us A Message</p>

        {% form 'contact' %}
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:1.25rem;margin-bottom:1.25rem;">
            <div>
              <label for="contact-fname" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;">First Name</label>
              <input id="contact-fname" type="text" name="contact[first_name]" placeholder="Maria" required
                style="width:100%;padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
            </div>
            <div>
              <label for="contact-lname" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;">Last Name</label>
              <input id="contact-lname" type="text" name="contact[last_name]" placeholder="García" required
                style="width:100%;padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
                onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
            </div>
          </div>

          <div style="margin-bottom:1.25rem;">
            <label for="contact-email" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;">Email</label>
            <input id="contact-email" type="email" name="contact[email]" placeholder="hola@example.com" required
              style="width:100%;padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
          </div>

          <div style="margin-bottom:1.25rem;">
            <label for="contact-subject" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;">Subject</label>
            <input id="contact-subject" type="text" name="contact[subject]" placeholder="What's on your mind?"
              style="width:100%;padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;"
              onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'">
          </div>

          <div style="margin-bottom:1.75rem;">
            <label for="contact-body" style="display:block;font-size:0.72rem;font-weight:700;letter-spacing:0.12em;text-transform:uppercase;color:var(--dark);margin-bottom:0.5rem;">Message</label>
            <textarea id="contact-body" name="contact[body]" rows="5" placeholder="Tell us everything…" required
              style="width:100%;padding:0.85rem 1rem;border:1.5px solid rgba(0,0,0,0.12);border-radius:10px;font-family:'Jost',sans-serif;font-size:0.9rem;color:var(--dark);background:#fff;outline:none;transition:border-color 0.2s;resize:vertical;"
              onfocus="this.style.borderColor='var(--pink)'" onblur="this.style.borderColor='rgba(0,0,0,0.12)'"></textarea>
          </div>

          <button type="submit"
            style="width:100%;padding:1.1rem;background:var(--pink);color:#fff;font-family:'Jost',sans-serif;font-weight:700;font-size:0.75rem;letter-spacing:0.18em;text-transform:uppercase;border:none;border-radius:9999px;cursor:pointer;transition:background 0.2s,transform 0.15s;box-shadow:0 4px 20px rgba(225,0,114,0.3);"
            onmouseover="this.style.background='var(--deep)'" onmouseout="this.style.background='var(--pink)'"
            onmousedown="this.style.transform='scale(0.98)'" onmouseup="this.style.transform='scale(1)'">
            {{ section.settings.btn_label }}
          </button>
        {% endform %}
      {%- endif -%}
    </div>

  </div>
</section>

<style>
  @media (max-width: 768px) {
    .contact-grid { grid-template-columns: 1fr !important; gap: 3rem !important; }
  }
</style>
<script>
  (function() {
    var grid = document.querySelector('.contact-grid-wrapper');
    if (grid) {
      grid.classList.add('contact-grid');
    }
  })();
</script>

{% schema %}
{
  "name": "Contact Page",
  "settings": [
    { "type": "header",   "content": "Hero" },
    { "type": "text",     "id": "eyebrow",         "label": "Eyebrow",          "default": "We'd Love To Hear From You" },
    { "type": "textarea", "id": "heading",          "label": "Heading",          "default": "Say\nHola" },
    { "type": "text",     "id": "subheading",       "label": "Subheading",       "default": "Whether you have a question about our products, a stockist enquiry, or just want to chat — we're all ears." },
    { "type": "header",   "content": "Contact Details" },
    { "type": "textarea", "id": "details_heading",  "label": "Details heading",  "default": "Let's\nTalk" },
    { "type": "textarea", "id": "details_body",     "label": "Details body",     "default": "We're a small but passionate team. Drop us a message and we'll get back to you within 1–2 business days." },
    { "type": "text",     "id": "phone",            "label": "Phone number",     "default": "+44 (0) 20 1234 5678" },
    { "type": "text",     "id": "email",            "label": "Email address",    "default": "hola@sencillo.co.uk" },
    { "type": "text",     "id": "location",         "label": "Location",         "default": "London, United Kingdom" },
    { "type": "header",   "content": "Form" },
    { "type": "text",     "id": "btn_label",        "label": "Submit button",    "default": "Send Message" },
    { "type": "text",     "id": "success_message",  "label": "Success message",  "default": "Thanks for reaching out! We'll get back to you within 1–2 business days." }
  ],
  "presets": [{ "name": "Contact Page" }]
}
{% endschema %}
