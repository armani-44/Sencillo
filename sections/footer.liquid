<footer style="background:var(--coral);padding:4rem 2rem 2rem;">
  <div style="max-width:1280px;margin:0 auto;">

    <div style="display:grid;grid-template-columns:1.3fr 1fr 1.3fr 1.7fr;gap:3rem;margin-bottom:2.5rem;align-items:start;" class="footer-top">

      <!-- Col 1: Logo + social -->
      <div>
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 300 }}" alt="{{ shop.name }}"
            style="height:130px;width:auto;filter:brightness(0) invert(1);display:block;margin-bottom:1.25rem;">
        {%- else -%}
          <p style="font-weight:900;font-size:2rem;color:#fff;margin-bottom:1.25rem;">{{ shop.name }}</p>
        {%- endif -%}
        <p style="font-weight:700;font-size:0.95rem;color:#fff;line-height:1.45;margin-bottom:1.25rem;">Let's get social!<br>Join the community</p>
        <div style="display:flex;gap:0.6rem;">
          <a href="{{ section.settings.tiktok_url }}" aria-label="TikTok" class="footer-social">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1V9.01a6.33 6.33 0 00-.79-.05 6.34 6.34 0 00-6.34 6.34 6.34 6.34 0 006.34 6.34 6.34 6.34 0 006.33-6.34V8.69a8.24 8.24 0 004.83 1.55V6.79a4.85 4.85 0 01-1.06-.1z"/></svg>
          </a>
          <a href="{{ section.settings.instagram_url }}" aria-label="Instagram" class="footer-social">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="{{ section.settings.snapchat_url }}" aria-label="Snapchat" class="footer-social">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M12.017 0C5.396 0 .029 5.367.029 11.987c0 5.079 3.158 9.417 7.618 11.162-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12.017 24c6.624 0 11.99-5.367 11.99-12C24.007 5.367 18.641 0 12.017 0z"/></svg>
          </a>
          <a href="{{ section.settings.facebook_url }}" aria-label="Facebook" class="footer-social">
            <svg width="16" height="16" fill="currentColor" viewBox="0 0 24 24"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
        </div>
      </div>

      <!-- Col 2: Nav links -->
      <div style="display:flex;flex-direction:column;gap:1.1rem;padding-top:0.5rem;">
        <a href="{{ routes.root_url }}" class="footer-nav-link">Home</a>
        <a href="{{ pages['our-story'].url }}" class="footer-nav-link">Our Story</a>
        <a href="#craft" class="footer-nav-link">The Craft</a>
        <a href="#newsletter" class="footer-nav-link">Join La Familia</a>
      </div>

      <!-- Col 3: More links -->
      <div style="display:flex;flex-direction:column;gap:1.1rem;padding-top:0.5rem;">
        <a href="{{ pages['customer-reviews'].url | default: '#' }}" class="footer-nav-link">Customer Reviews</a>
        <a href="{{ pages['contact'].url | default: routes.root_url | append: 'pages/contact' }}" class="footer-nav-link">Contact Us</a>
        <a href="{{ routes.account_url }}" class="footer-nav-link">Manage My Subscription</a>
        <a href="{{ pages['terms-of-service'].url | default: shop.terms_of_service_url }}" class="footer-nav-link">Terms of Service</a>
        <a href="{{ pages['privacy-policy'].url | default: shop.privacy_policy_url }}" class="footer-nav-link">Privacy Policy</a>
      </div>

      <!-- Col 4: Newsletter signup -->
      <div>
        <h2 style="font-weight:900;font-size:2.15rem;line-height:1.05;letter-spacing:-0.01em;text-transform:uppercase;color:#fff;margin-bottom:1.5rem;">
          Sign Up To<br>Become A Member
        </h2>
        {% form 'customer' %}
          <input type="hidden" name="contact[tags]" value="newsletter">
          <div style="display:flex;">
            <input type="email" name="contact[email]" placeholder="Email@example.com" class="footer-email-input"
              style="flex:1;min-width:0;padding:0.85rem 1.1rem;background:transparent;border:2px solid #fff;border-right:none;color:#fff;font-size:0.88rem;font-family:inherit;outline:none;" required>
            <button type="submit" style="background:#fff;border:2px solid #fff;color:var(--coral);font-weight:700;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;padding:0.85rem 1.4rem;cursor:pointer;font-family:inherit;white-space:nowrap;flex-shrink:0;">Subscribe</button>
          </div>
          {%- if form.posted_successfully? -%}
            <p style="margin-top:0.75rem;font-size:0.82rem;color:#fff;">Thanks for joining!</p>
          {%- endif -%}
        {% endform %}
      </div>

    </div>

    <p style="font-size:0.78rem;color:rgba(255,255,255,0.8);">© {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</p>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    { "type": "image_picker", "id": "logo",          "label": "Logo" },
    { "type": "url",          "id": "tiktok_url",    "label": "TikTok URL" },
    { "type": "url",          "id": "instagram_url", "label": "Instagram URL" },
    { "type": "url",          "id": "snapchat_url",  "label": "Snapchat URL" },
    { "type": "url",          "id": "facebook_url",  "label": "Facebook URL" }
  ]
}
{% endschema %}
