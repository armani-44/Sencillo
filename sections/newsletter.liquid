<section id="newsletter" style="background:var(--yellow);padding:5rem 2rem;text-align:center;">
  <div style="max-width:660px;margin:0 auto;">
    <div class="reveal">
      <h2 class="display" style="font-size:clamp(3.6rem,8vw,6.5rem);color:var(--dark);margin-bottom:1.5rem;line-height:1;">
        {{ section.settings.heading }}
      </h2>
      <p style="font-weight:400;font-size:1rem;line-height:1.7;color:rgba(0,0,0,0.7);max-width:520px;margin:0 auto 2.5rem;">
        {{ section.settings.body }}
      </p>

      {% form 'customer' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div style="display:flex;max-width:520px;margin:0 auto 1rem;box-shadow:0 4px 24px rgba(0,0,0,0.1);border-radius:9999px;overflow:hidden;">
          <input type="email" name="contact[email]" placeholder="{{ section.settings.placeholder }}"
            style="flex:1;padding:1.1rem 1.8rem;font-family:'Jost',sans-serif;font-weight:400;font-size:0.95rem;border:none;outline:none;background:#fff;color:var(--dark);"
            required>
          <button type="submit"
            style="background:var(--deep);color:#fff;font-family:'Jost',sans-serif;font-weight:700;font-size:0.7rem;letter-spacing:0.17em;text-transform:uppercase;padding:1.1rem 2rem;border:none;cursor:pointer;white-space:nowrap;transition:background 0.2s;"
            onmouseover="this.style.background='var(--pink)'" onmouseout="this.style.background='var(--deep)'">
            {{ section.settings.btn_label }}
          </button>
        </div>
        {%- if form.posted_successfully? -%}
          <p style="margin-bottom:0.75rem;font-weight:600;color:var(--deep);">You're in! Welcome to La Familia.</p>
        {%- endif -%}
      {% endform %}

      <p style="font-size:0.78rem;color:rgba(0,0,0,0.45);letter-spacing:0.02em;">{{ section.settings.disclaimer }}</p>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text",     "id": "heading",     "label": "Heading",             "default": "Join La Familia!" },
    { "type": "textarea", "id": "body",        "label": "Body copy",           "default": "Sign up to our newsletter and be the first to know about new flavors, exclusive drops, and events near you." },
    { "type": "text",     "id": "placeholder", "label": "Email placeholder",   "default": "Enter your email address" },
    { "type": "text",     "id": "btn_label",   "label": "Button label",        "default": "Subscribe" },
    { "type": "text",     "id": "disclaimer",  "label": "Disclaimer text",     "default": "No spam, ever. Unsubscribe anytime." }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
