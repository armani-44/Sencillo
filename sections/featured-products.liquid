{%- assign featured_collection = collections[section.settings.collection] -%}

<section id="products" style="padding:6.5rem 2rem;background:#fff;">
  <div style="max-width:1100px;margin:0 auto;">

    <!-- Header row aligned to card edges -->
    <div class="reveal" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,460px));gap:2.25rem;justify-content:center;align-items:flex-end;margin-bottom:3.5rem;">
      <div>
        <p class="eyebrow" style="color:var(--pink);margin-bottom:0.6rem;">{{ section.settings.eyebrow }}</p>
        <h2 class="display" style="font-size:clamp(2.6rem,5vw,3.8rem);color:var(--dark);">{{ section.settings.heading }}</h2>
      </div>
      <div style="text-align:right;">
        <a href="{{ section.settings.view_all_url | default: routes.root_url | append: 'collections/all' }}"
          style="font-weight:700;font-size:0.7rem;letter-spacing:0.14em;text-transform:uppercase;color:var(--pink);border-bottom:2px solid var(--pink);padding-bottom:2px;transition:opacity 0.2s;text-decoration:none;"
          onmouseover="this.style.opacity='0.6'" onmouseout="this.style.opacity='1'">
          View All Drinks →
        </a>
      </div>
    </div>

    <!-- Product grid -->
    <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,460px));gap:2.25rem;justify-content:center;" class="products-grid">
      {%- if featured_collection != blank -%}
        {%- for product in featured_collection.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for product in collections.all.products limit: section.settings.products_to_show -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- endif -%}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "Featured Products",
  "settings": [
    { "type": "text",       "id": "eyebrow",          "label": "Eyebrow",           "default": "Our Products" },
    { "type": "text",       "id": "heading",          "label": "Heading",           "default": "The Lineup" },
    { "type": "collection", "id": "collection",       "label": "Collection" },
    { "type": "range",      "id": "products_to_show", "label": "Products to show",  "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "url",        "id": "view_all_url",     "label": "View all link URL" }
  ],
  "presets": [{ "name": "Featured Products" }]
}
{% endschema %}
