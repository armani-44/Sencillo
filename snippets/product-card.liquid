{% comment %}
  Renders a product card.
  Usage: {% render 'product-card', product: product %}
{% endcomment %}

{% unless cardQtyScriptLoaded %}
  {% assign cardQtyScriptLoaded = true %}
  <script>
  if (!window._cardQtyReady) {
    window._cardQtyReady = true;
    document.addEventListener('click', function(e) {
      var btn = e.target.closest('.card-qty-dec, .card-qty-inc');
      if (!btn) return;
      var input = btn.closest('form').querySelector('.card-qty-input');
      if (!input) return;
      var v = parseInt(input.value, 10) || 1;
      input.value = btn.classList.contains('card-qty-inc') ? v + 1 : Math.max(1, v - 1);
    });
  }
  </script>
{% endunless %}

{%- liquid
  assign card_class = 'product-card'
  assign hover_class = product.handle
-%}

<div class="{{ card_class }} {{ hover_class }} reveal">
  <a href="{{ product.url }}" style="display:block;text-decoration:none;color:inherit;">
    <div style="height:360px;overflow:hidden;position:relative;background:{{ product.metafields.custom.card_bg_gradient | default: 'linear-gradient(148deg,#FFEDF6,#FFD4EE)' }};">
      {%- if product.featured_image != blank -%}
        <img src="{{ product.featured_image | image_url: width: 600 }}"
          alt="{{ product.featured_image.alt | escape }}" class="card-img"
          style="object-position:{{ product.metafields.custom.image_position | default: 'center center' }};">
      {%- endif -%}

      <!-- Gradient overlay -->
      <div style="position:absolute;inset:0;background:linear-gradient(to top,rgba(147,4,78,0.6) 0%,rgba(147,4,78,0.15) 45%,transparent 70%);pointer-events:none;"></div>

      <!-- Badge -->
      {%- if product.tags contains 'bestseller' -%}
        <div style="position:absolute;top:1.1rem;left:1.1rem;background:var(--pink);padding:0.3rem 0.85rem;border-radius:2px;">
          <span style="font-weight:700;font-size:0.58rem;letter-spacing:0.16em;text-transform:uppercase;color:#fff;">Bestseller</span>
        </div>
      {%- elsif product.tags contains 'new' -%}
        <div style="position:absolute;top:1.1rem;left:1.1rem;background:var(--yellow);padding:0.3rem 0.85rem;border-radius:2px;">
          <span style="font-weight:700;font-size:0.58rem;letter-spacing:0.16em;text-transform:uppercase;color:var(--dark);">New</span>
        </div>
      {%- endif -%}

      <!-- Name overlay -->
      <div style="position:absolute;bottom:1.5rem;left:1.5rem;right:1.5rem;">
        <p style="font-weight:900;font-size:1.65rem;letter-spacing:-0.025em;color:#fff;text-transform:uppercase;text-shadow:0 3px 20px rgba(0,0,0,0.4);line-height:1.05;">
          {{ product.title }}
        </p>
        {%- if product.metafields.custom.subtitle != blank -%}
          <p style="font-weight:300;font-size:0.82rem;color:rgba(255,255,255,0.88);font-style:italic;margin-top:3px;letter-spacing:0.02em;">
            {{ product.metafields.custom.subtitle }}
          </p>
        {%- endif -%}
      </div>
    </div>
  </a>

  <div style="padding:1.6rem;">
    <!-- Reviews (metafield or static) -->
    {%- if product.metafields.reviews.rating != blank -%}
      <div style="display:flex;align-items:center;gap:0.55rem;margin-bottom:0.7rem;">
        <span class="stars">★★★★★</span>
        <span style="font-weight:600;font-size:0.72rem;color:#999;letter-spacing:0.02em;">
          {{ product.metafields.reviews.rating }} · {{ product.metafields.reviews.rating_count }} reviews
        </span>
      </div>
    {%- endif -%}

    <p style="font-weight:500;font-size:0.88rem;color:#555;margin-bottom:0.35rem;line-height:1.5;">
      {{ product.description | strip_html | truncate: 80 }}
    </p>
    <p style="font-size:0.74rem;color:#bbb;margin-bottom:1.5rem;letter-spacing:0.04em;">
      {{ product.metafields.custom.volume | default: '150ml' }} &nbsp;·&nbsp; {{ product.metafields.custom.abv | default: '15% ABV' }}
    </p>

    <div style="display:flex;align-items:baseline;justify-content:space-between;margin-bottom:0.85rem;">
      <span style="font-weight:900;font-size:1.6rem;color:var(--dark);letter-spacing:-0.02em;">
        {{ product.price | money }}
      </span>
    </div>
    {% form 'product', product, class: 'js-add-to-cart' %}
      <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">
      <div style="display:flex;align-items:center;gap:0.6rem;">
        <!-- Qty control -->
        <div style="display:flex;align-items:center;border:1px solid rgba(0,0,0,0.12);border-radius:9999px;flex-shrink:0;">
          <button type="button" class="card-qty-dec"
            style="width:32px;height:32px;background:none;border:none;cursor:pointer;font-size:1.1rem;font-weight:700;color:var(--dark);display:flex;align-items:center;justify-content:center;line-height:1;">−</button>
          <input type="number" name="quantity" value="1" min="1" class="card-qty-input"
            style="width:34px;height:32px;border:none;border-left:1px solid rgba(0,0,0,0.08);border-right:1px solid rgba(0,0,0,0.08);text-align:center;font-family:'Jost',sans-serif;font-weight:700;font-size:0.85rem;color:var(--dark);outline:none;-moz-appearance:textfield;background:#fff;">
          <button type="button" class="card-qty-inc"
            style="width:32px;height:32px;background:none;border:none;cursor:pointer;font-size:1.1rem;font-weight:700;color:var(--dark);display:flex;align-items:center;justify-content:center;line-height:1;">+</button>
        </div>
        <!-- Add to bag -->
        <button type="submit" class="add-to-bag" style="flex:1;padding:0.8rem 1rem;">
          Add to Bag
        </button>
      </div>
    {% endform %}
  </div>
</div>
